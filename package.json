{
  "name": "giva-ecosystem",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n frontend,backend \"pnpm run dev:frontend\" \"pnpm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "pnpm -F giva-backend run dev",
    "build": "vite build && pnpm -F giva-backend run build",
    "build:all": "pnpm run build",
    "preview": "vite preview",
    "start": "pnpm -F giva-backend run start",
    "db:migrate": "pnpm -F giva-backend run db:migrate",
    "db:seed": "pnpm -F giva-backend run seed",
    "db:push": "pnpm -F giva-backend run db:push",
    "prisma:generate": "pnpm -F giva-backend exec prisma generate",
    "prisma:studio": "pnpm -F giva-backend exec prisma studio",
    "vercel-build": "pnpm prisma:generate && pnpm run build && pnpm db:migrate || true",
    "vercel-migrate": "pnpm db:migrate"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.562.0",
    "pdfjs-dist": "^5.5.207",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.2.1",
    "sharp": "^0.34.5",
    "typescript": "~5.8.3",
    "vite": "^6.4.1"
  }
}