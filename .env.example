# ============================================
# DATABASE
# ============================================
# PostgreSQL connection string (required for production)
# Format: postgresql://user:password@host:port/database
# Get from: Vercel Postgres, Neon, Railway, or your managed DB
DATABASE_URL="postgresql://user:password@localhost:5432/moova_ecosystem"

# ============================================
# FRONTEND (VITE)
# ============================================
# API endpoint for frontend
VITE_API_URL=http://localhost:5000

# Gemini AI API Key for frontend features
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# BACKEND (EXPRESS + PRISMA)
# ============================================
# Environment mode
NODE_ENV=development

# Server port (Vercel will override to 5000)
PORT=5000

# CORS allowed origin
CORS_ORIGIN=http://localhost:3000

# JWT secret for token signing (min 32 characters recommended)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Gemini API key for backend features
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# FILE UPLOADS
# ============================================
# Upload directory path (relative to backend root)
UPLOAD_DIR=./uploads

# Maximum file size in bytes (10MB default)
MAX_FILE_SIZE=10485760

# ============================================
# ADMIN CREDENTIALS (for seeding)
# ============================================
# These are used to create initial admin account when database is seeded
ADMIN_EMAIL=admin@moova.com
ADMIN_PASSWORD=ChangeThisPassword123!

# ============================================
# EMAIL (Optional - for notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@moova.com
SMTP_FROM_NAME=GIVA Moova

# ============================================
# DEPLOYMENT NOTES
# ============================================
# For Vercel deployment:
# 1. Copy this file and remove the comments
# 2. Set all variable values
# 3. Add them to Vercel Project Settings
# 4. Run: vercel env pull
# 5. Run migrations: pnpm prisma migrate deploy
# 6. Run seed: pnpm db:seed
